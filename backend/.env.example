# 服务器配置
PORT=3000
NODE_ENV=development

# 腾讯混元 API
HUNYUAN_SECRET_ID=AKIDxxxxxxxxxxxxxxxxxxxxxx
HUNYUAN_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HUNYUAN_REGION=ap-guangzhou

# Replicate API（备用）
REPLICATE_API_KEY=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# 七牛云 Kodo
QINIU_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx
QINIU_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx
QINIU_BUCKET=your-bucket-name
QINIU_DOMAIN=http://your-domain.com
QINIU_REGION=z2

# PicWish 背景抠图 API（备用方案）
PICWISH_API_KEY=YOUR_PICWISH_API_KEY

# 本地 GPU 背景抠图（Rembg）
REMBG_API_URL=http://localhost:7000
USE_LOCAL_GPU_BACKGROUND=false

# Redis（可选，用于任务队列）
REDIS_HOST=localhost
REDIS_PORT=6379

# 数据库（可选，MongoDB）
MONGODB_URI=mongodb://localhost:27017/3d-head-modeling
